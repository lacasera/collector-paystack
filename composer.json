{
    "name": "lacasera/collector-paystack",
    "description": "Subscription billing for Laravel with PayStack: a hosted-style billing portal, plan switching, webhooks and a Cashier-like API.",
    "keywords": [
        "laravel",
        "paystack",
        "subscriptions",
        "billing",
        "payments",
        "recurring-payments",
        "cashier",
        "lacasera"
    ],
    "homepage": "https://github.com/lacasera/collector-paystack",
    "support": {
        "issues": "https://github.com/lacasera/collector-paystack/issues",
        "source": "https://github.com/lacasera/collector-paystack"
    },
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Agyenim Boateng",
            "email": "aboateng62@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/database": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "illuminate/http": "^12.0|^13.0",
        "illuminate/validation": "^12.0|^13.0",
        "inertiajs/inertia-laravel": "^1.3.1|^2.0",
        "moneyphp/money": "^4.5",
        "guzzlehttp/guzzle": "^7.8",
        "ext-intl": "*"
    },
    "require-dev": {
        "laravel/pint": "^1.17",
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Collector\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Collector\\Tests\\": "tests",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\": "workbench/database/"
        },
        "files": [
            "tests/helpers.php"
        ]
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "pint": "./vendor/bin/pint --dirty"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
              "Collector\\CollectorServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
