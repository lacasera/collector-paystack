# Dependencies
/node_modules
/vendor

# Build outputs
# NOTE: The compiled billing-portal assets (public/js/app.js, public/css/collector.css)
# are intentionally committed — the portal inlines them at runtime and the package
# ships them pre-built, so they must not be ignored here.
/public/hot
/public/storage
/storage/*.key

# Environment files
.env
.env.backup
.env.production

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Testing
/coverage
/.phpunit.cache
.phpunit.result.cache
/test-results
/playwright-report
/playwright/.cache
workbench/database/*.sqlite

# Build tools
/build
/dist

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Temporary directories
.tmp
.temp